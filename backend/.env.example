# CodeCraft backend environment example
# Copy this to backend/.env and fill the values you need. Optional integrations
# can stay empty.
# If you change PORT, also update frontend/.env -> VITE_API_URL.

# Core app
NODE_ENV=development
PORT=5001
REQUEST_BODY_LIMIT=12mb
DATABASE_URL=mongodb://localhost:27017/codecraft

# Auth
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=7d

# Google Sign-In
# Keep GOOGLE_CLIENT_ID the same as frontend/.env -> VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI APIs
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Email / SMTP
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Mentor notification emails
MENTOR_ZULFIQUAR_EMAIL=zulfiquar@example.com
MENTOR_ANAS_EMAIL=anas@example.com
MENTOR_VIPUL_EMAIL=vipul@example.com
MENTOR_RAJ_EMAIL=raj@example.com
MENTOR_FURQAN_EMAIL=furqan@example.com

# Frontend URLs for CORS
# Use a comma-separated list in FRONTEND_URLS when you want to allow both local
# and deployed frontends.
FRONTEND_URLS=http://localhost:5173,https://codecraft-frontend-9qqk.onrender.com
FRONTEND_URL=http://localhost:5173

# Optional dashboard integrations
# This improves GitHub rate limits and dashboard data quality.
GITHUB_API_TOKEN=your-github-api-token

# Job sync controls
ENABLE_JOB_SYNC=true
RUN_JOB_SYNC_ON_STARTUP=true

# Adzuna Jobs API
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=in
ADZUNA_WHAT=software developer
ADZUNA_WHERE=India
ADZUNA_RESULTS_PER_PAGE=20

# RapidAPI Jobs API
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=example-jobs-api.p.rapidapi.com
RAPIDAPI_JOBS_URL=https://example-jobs-api.p.rapidapi.com/search
RAPIDAPI_QUERY=software developer
RAPIDAPI_LOCATION=India
RAPIDAPI_PAGE=1

# Judge0 API
# Direct Judge0 CE works with JUDGE0_API_URL alone. For RapidAPI, also fill
# JUDGE0_API_KEY and JUDGE0_API_HOST.
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_AUTH_HEADER=X-Auth-Token
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
