# Database Configuration
DATABASE_URL=mongodb://localhost:27017/codecraft

# Server Configuration
PORT=5000
NODE_ENV=development
REQUEST_BODY_LIMIT=12mb

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# OAuth & First-Party Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Groq Configuration (for AI mentor features)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Email Configuration (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Mentor notification emails
MENTOR_ZULFIQUAR_EMAIL=zulfiquar@example.com
MENTOR_ANAS_EMAIL=anas@example.com
MENTOR_VIPUL_EMAIL=vipul@example.com
MENTOR_RAJ_EMAIL=raj@example.com

# Frontend URLs (for CORS)
# Use a comma-separated list when both local and deployed frontends should be allowed.
FRONTEND_URLS=http://localhost:5173,https://codecraft-frontend-9qqk.onrender.com
FRONTEND_URL=http://localhost:5173

# Optional: GitHub token for dashboard sync.
# This improves rate limits and lets the dashboard use the contribution calendar
# instead of only the public events feed. For private contribution visibility,
# use a token from the same GitHub account.
GITHUB_API_TOKEN=your-github-api-token

# Jobs aggregation (external metadata only, no scraping)
ENABLE_JOB_SYNC=true
RUN_JOB_SYNC_ON_STARTUP=true
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=in
ADZUNA_WHAT=software developer
ADZUNA_WHERE=India
ADZUNA_RESULTS_PER_PAGE=20
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=example-jobs-api.p.rapidapi.com
RAPIDAPI_JOBS_URL=https://example-jobs-api.p.rapidapi.com/search
RAPIDAPI_QUERY=software developer
RAPIDAPI_LOCATION=India
RAPIDAPI_PAGE=1

# Judge0 API (for code execution)
# Default below uses direct Judge0 CE. For RapidAPI, replace the URL and fill JUDGE0_API_KEY/JUDGE0_API_HOST.
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_AUTH_HEADER=X-Auth-Token
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
