# CodeCraft frontend environment example
# Copy this to frontend/.env. Only browser-safe values belong here.
# Secrets should stay in backend/.env.

# Core frontend
# Keep this in sync with backend/.env -> PORT.
VITE_API_URL=http://localhost:5001/api
VITE_ENV=development

# Google Sign-In
# Keep this the same as backend/.env -> GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Optional browser-side services
VITE_JUDGE0_API_URL=https://ce.judge0.com
